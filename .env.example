# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Neon Postgres
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Criptografia de dados sensiveis (CPF, chave PIX)
DB_ENCRYPTION_KEY=change-me-32-bytes-minimum-xxxxxxxx

# 4P Finance
FOUR_P_DRIVER=mock
NEXT_PUBLIC_FOUR_P_DRIVER=mock
FOUR_P_API_KEY=
FOUR_P_API_BASE=https://api.4p.finance
FOUR_P_WEBHOOK_IP_ALLOWLIST=44.196.63.157

# Solana / Kamino
# KAMINO_ENV:
#   mock     -> in-memory (dev rápido, sem gas)
#   staging  -> Kamino Lend Staging (programa SLendK7... no cluster mainnet-beta)
#                USDC real de mainnet · seguro pra testes (valores pequenos)
#   mainnet  -> Kamino Lend produção
# Nota: Kamino Lend NÃO tem devnet. Para testes on-chain use "staging".
KAMINO_ENV=mock
NEXT_PUBLIC_KAMINO_ENV=mock
# APY acelerado pra demo em mock (default 3650% = ~10%/hora). Use 6.25 pra taxa realista.
MOCK_KAMINO_APY=3650
# Optional overrides (deixe vazio para usar presets por env)
SOLANA_RPC_URL=
# Exposto pro client (Privy SDK) — normalmente só em produção se usar RPC premium (Helius/QuickNode)
NEXT_PUBLIC_SOLANA_RPC_URL=
KAMINO_PROGRAM_ID=
KAMINO_MARKET_PUBKEY=

# Cron
CRON_SECRET=
# Quando NÃO usa Vercel cron, habilita scheduler in-process (reconcile 4P a cada 1min, snapshot a cada 6h)
ENABLE_IN_PROCESS_CRON=true
